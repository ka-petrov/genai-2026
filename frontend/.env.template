# Map tile style URL (MapLibre GL).
# Default: OpenFreeMap Liberty style. Replace with your own vector tile URL if needed.
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Google Maps JavaScript API key — enables address autocomplete on the landing page.
# Leave blank to disable autocomplete (the address field still works as plain text).
VITE_GOOGLE_MAPS_API_KEY=

# Set to "false" to call the real backend API.
# Any other value (or commented out) uses built-in mock responses for local dev.
# VITE_USE_MOCKS=false
